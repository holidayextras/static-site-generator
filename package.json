{
  "name": "@holidayextras/static-site-generator",
  "version": "9.6.9",
  "description": "Holiday Extras Static Site Generator in metalsmith / react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holidayextras/static-site-generator.git"
  },
  "author": "Richard Stevens <richard.stevens@holidayextras.com",
  "license": "MIT",
  "main": "lib/index.js",
  "watch": {
    "trans": "src"
  },
  "scripts": {
    "build": "npm run trans",
    "trans": "babel src/ -d lib/",
    "lint": "npm run lint",
    "test": "mocha --require @babel/register test/simulate-request.test.js --timeout 30000"
  },
  "standard": {
    "ignore": [
      "src/metalsmith-prismic.js"
    ]
  },
  "dependencies": {
    "async": "^3.2.6",
    "lodash": "^4.17.23",
    "meta-marked": "^0.5.0",
    "metalsmith": "^2.7.0",
    "metalsmith-assets-improved": "^1.0.1",
    "metalsmith-markdown": "^1.3.0",
    "metalsmith-react-tpl": "^3.0.2",
    "prismic.io": "^3.6.1",
    "rimraf": "^6.1.3",
    "underscore": "^1.13.8"
  },
  "devDependencies": {
    "babel-loader": "^9.2.0",
    "mocha": "^11.0.0",
    "@babel/cli": "^7.28.6",
    "@babel/register": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "debug": "^4.4.3",
    "react": "^16.6.0",
    "react-dom": "^16.6.0",
    "react-redux": "^7.0.0",
    "redux": "^5.0.1",
    "standard": "^17.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@holidayextras",
    "access": "restricted"
  },
  "owner": "audience"
}
